+// StartMonitoringByTag запускает мониторинг singbox туннеля по тегу.
+func (f *Facade) StartMonitoringByTag(tag, tunnelName string) {
+	f.loadSingboxConfigsIfNeeded()
+	cfg, ok := f.singboxConfigs[tag]
+	if !ok {
